GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=yourpassword

# Absolute or relative path to your git-tracked data directory
DATA_DIR=./data

# How many days back to fetch on the very first run (no .last_sync file exists).
# After the first run, .last_sync takes over and this is ignored.
INITIAL_LOOKBACK_DAYS=30

# Leave blank to skip Cloudflare upload
# Base URL only — no trailing slash, no /api/workouts
CF_WORKER_URL=https://your-worker.your-subdomain.workers.dev
CF_API_KEY=your_api_key_here